{
  "name": "@clyf/core",
  "version": "1.0.0",
  "description": "Generate TypeScript type files from JSON objects during development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "typescript",
    "types",
    "json",
    "codegen",
    "developer-tools",
    "type-generation",
    "api"
  ],
  "author": "Faith Adetona",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fktona/clyf"
  },
  "bugs": {
    "url": "https://github.com/fktona/clyf/issues"
  },
  "homepage": "https://github.com/fktona/clyf#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "quicktype-core": "^23.0.0"
  }
}
