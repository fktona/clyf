{
  "name": "@clyf/core",
  "version": "1.0.0",
  "description": "Generate TypeScript type files from JSON objects during development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
