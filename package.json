  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fktona/clyf"
  },
  "bugs": {
    "url": "https://github.com/fktona/clyf/issues"
  },
  "homepage": "https://github.com/fktona/clyf#readme",
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "quicktype-core": "^23.0.0"
  }
}
